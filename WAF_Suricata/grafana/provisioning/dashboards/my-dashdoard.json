{
  "title": "Security Monitoring",
  "panels": [
    {
      "title": "WAF блокировки (последний час)",
      "type": "stat",
      "targets": [
        {
          "expr": "count_over_time({job=\"nginx\", status=\"403\"}[1h])",
          "legendFormat": "Заблокировано"
        }
      ],
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4}
    },
    {
      "title": "Логи Suricata (alert)",
      "type": "logs",
      "targets": [
        {
          "expr": "{job=\"suricata\", event_type=\"alert\"}"
        }
      ],
      "gridPos": {"x": 0, "y": 5, "w": 12, "h": 8}
    },
    {
      "title": "Ошибки приложения (ERROR)",
      "type": "stat",
      "targets": [
        {
          "expr": "count_over_time({job=\"app\", level=\"ERROR\"}[1h])"
        }
      ],
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4}
    }
  ],
  "schemaVersion": 36,
  "time": {"from": "now-1h", "to": "now"}
}