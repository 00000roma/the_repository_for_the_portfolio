# Обнаружение сканирования портов (SYN-сканирование)
alert tcp $EXTERNAL_NET any -> $HOME_NET 1:1024 (msg:"PORT SCAN"; flags:S; threshold: type both, track by_src, count 20, seconds 10; sid:1000001;)

# Пример SQL-инъекции через GET-параметр
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"SQL Injection Attempt"; flow:to_server,established; content:"' OR '1'='1"; http_uri; sid:1000002;)

# Обнаружение User-Agent с подозрительным содержимым (например, сканеры)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"Suspicious User-Agent"; flow:to_server,established; content:"nessus"; http_user_agent; sid:1000003;)